<div class="contact-main">
	<div class="container mt-150 text-center position-relative">
		<h1 class="text-white mb-5 text-center fw-light">Get the latest updates from Stories</h1>
		<div class="row">
			<div class="col-md-4 offset-md-4">
				<%= form_for @signup do |f| %>
					<div class="form-group">
						<%= f.label :firstname %>
						<%= f.text_field :firstname, class: "form-control" %>
					</div>
					<div class="form-group">
						<%= f.label :email %>
						<%= f.text_field :email, class: "form-control" %>
					</div>
					<br/>
					<%= f.submit "Sign-Up", class:"btn btn-primary btn-sm" %>
				<% end %>
			</div>
		</div>
	</div>
</div>

